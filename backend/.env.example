# PostgreSQL (also consumed by docker-compose)
POSTGRES_USER=clocksy
POSTGRES_PASSWORD=clocksy
POSTGRES_DB=clocksy
POSTGRES_PORT=5432

# Prisma connection string
DATABASE_URL=postgresql://clocksy:clocksy@localhost:5432/clocksy?schema=public

# Auth — JWT signing/verification secret (use a long random value in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# MinIO / S3-compatible storage (also consumed by docker-compose)
MINIO_ROOT_USER=clocksy
MINIO_ROOT_PASSWORD=clocksy-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=clocksy
S3_SECRET_KEY=clocksy-secret
S3_BUCKET=time-tracker
S3_FORCE_PATH_STYLE=true

# Server
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
